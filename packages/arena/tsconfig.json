{
    "extends": "@tsconfig/svelte",
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "outDir": "dist",
        "rootDir": "src",
        "strict": true,
        "skipLibCheck": true,
        "composite": true
    },
    "references":[
        {"path": "../shared"}
    ],
    "include": ["src/**/*.ts", "src/**/*.svelte"]
}
